<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefWidth="820" prefHeight="580"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ForgotPasswordController"
            style="-fx-background-color: #f5f5f0;">
    <children>

        <!-- Decorative green circle top-right -->
        <Region layoutX="620" layoutY="-60" prefWidth="260" prefHeight="260"
                style="-fx-background-color: #2ecc71; -fx-background-radius: 130; -fx-opacity: 0.15;"/>

        <!-- Decorative purple circle bottom-left -->
        <Region layoutX="-60" layoutY="400" prefWidth="220" prefHeight="220"
                style="-fx-background-color: #5b4b8a; -fx-background-radius: 110; -fx-opacity: 0.12;"/>

        <!-- Center card -->
        <VBox alignment="TOP_CENTER" spacing="0"
              prefWidth="380" layoutX="220" layoutY="80"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-padding: 40 35 35 35;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.10),20,0,0,4);">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="4" style="-fx-padding: 0 0 20 0;">
                <Label text="🌿" style="-fx-font-size: 36px;"/>
                <Label text="MindNest"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;
                              -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';"/>
                <Label text="A safe space for your thoughts"
                       style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
            </VBox>

            <!-- ═══════════════════════════════════ -->
            <!--  STEP 1 — Enter Email               -->
            <!-- ═══════════════════════════════════ -->
            <VBox fx:id="stepEmailPane" spacing="14" alignment="CENTER">
                <Label text="Forgot Password?"
                       style="-fx-font-size: 17px; -fx-font-weight: bold;
                              -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';"/>
                <Label text="Enter your email and we'll send you a reset code."
                       wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;
                              -fx-text-alignment: center; -fx-alignment: center;"/>

                <TextField fx:id="emailField"
                           promptText="Email address"
                           prefHeight="42" prefWidth="310"
                           style="-fx-background-radius: 10; -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 10; -fx-font-size: 13px; -fx-padding: 0 12;"/>

                <Label fx:id="step1ErrorLabel" text="" wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"
                       visible="false" managed="false"/>

                <Button fx:id="sendOtpButton" text="Send Code"
                        onAction="#handleSendOtp"
                        prefHeight="44" prefWidth="310"
                        style="-fx-background-color: #5b4b8a; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 25; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Remember your password?"
                           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    <Hyperlink text="Log in" onAction="#goLogin"
                               style="-fx-font-size: 12px; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <!-- ═══════════════════════════════════ -->
            <!--  STEP 2 — Enter OTP                 -->
            <!-- ═══════════════════════════════════ -->
            <VBox fx:id="stepOtpPane" spacing="14" alignment="CENTER" visible="false" managed="false">
                <Label text="Check Your Email"
                       style="-fx-font-size: 17px; -fx-font-weight: bold;
                              -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';"/>

                <Label fx:id="otpSentLabel"
                       text="Code sent!"
                       wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #2ecc71;
                              -fx-text-alignment: center; -fx-alignment: center;"/>

                <Label text="Enter the 6-digit code below:"
                       style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;"/>

                <TextField fx:id="otpField"
                           promptText="_ _ _ _ _ _"
                           prefHeight="52" prefWidth="200"
                           style="-fx-background-radius: 10; -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 10; -fx-font-size: 22px;
                                  -fx-font-weight: bold; -fx-alignment: center;
                                  -fx-letter-spacing: 6px;"/>

                <Label fx:id="step2ErrorLabel" text="" wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"
                       visible="false" managed="false"/>

                <Button fx:id="verifyOtpButton" text="Verify Code"
                        onAction="#handleVerifyOtp"
                        prefHeight="44" prefWidth="310"
                        style="-fx-background-color: #5b4b8a; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 25; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Didn't receive the code?"
                           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    <Hyperlink text="Resend" onAction="#handleResendOtp"
                               style="-fx-font-size: 12px; -fx-text-fill: #5b4b8a; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <!-- ═══════════════════════════════════ -->
            <!--  STEP 3 — New Password              -->
            <!-- ═══════════════════════════════════ -->
            <VBox fx:id="stepPasswordPane" spacing="14" alignment="CENTER" visible="false" managed="false">
                <Label text="Set New Password"
                       style="-fx-font-size: 17px; -fx-font-weight: bold;
                              -fx-text-fill: #2c3e50; -fx-font-family: 'Segoe UI';"/>
                <Label text="Choose a strong password for your account."
                       wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #95a5a6;
                              -fx-text-alignment: center; -fx-alignment: center;"/>

                <PasswordField fx:id="newPasswordField"
                               promptText="New password"
                               prefHeight="42" prefWidth="310"
                               style="-fx-background-radius: 10; -fx-border-color: #e0e0e0;
                                      -fx-border-radius: 10; -fx-font-size: 13px; -fx-padding: 0 12;"/>

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm new password"
                               prefHeight="42" prefWidth="310"
                               style="-fx-background-radius: 10; -fx-border-color: #e0e0e0;
                                      -fx-border-radius: 10; -fx-font-size: 13px; -fx-padding: 0 12;"/>

                <Label fx:id="step3ErrorLabel" text="" wrapText="true" prefWidth="310"
                       style="-fx-font-size: 12px; -fx-text-fill: #e74c3c;"
                       visible="false" managed="false"/>

                <Button fx:id="resetButton" text="Reset Password"
                        onAction="#handleResetPassword"
                        prefHeight="44" prefWidth="310"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 25; -fx-cursor: hand;"/>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Back to"
                           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                    <Hyperlink text="Log in" onAction="#goLogin"
                               style="-fx-font-size: 12px; -fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
